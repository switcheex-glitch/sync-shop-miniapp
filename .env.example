# Скопируйте в .env.local для локальной разработки и пропишите те же значения в Vercel (Project Settings → Environment Variables).
# ВНИМАНИЕ: SUPABASE_SERVICE_ROLE_KEY и TELEGRAM_BOT_TOKEN — серверные секреты, НЕ должны иметь префикс NEXT_PUBLIC_.

# Токен бота-магазина из @BotFather (нужен для проверки подписи initData Telegram)
TELEGRAM_BOT_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Юзернейм бота поддержки (для кнопки «Поддержка»)
NEXT_PUBLIC_SUPPORT_BOT=Sync_Industries_Support_Bot
